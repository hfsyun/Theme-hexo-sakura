{% macro render(posts) %}
<div class="post-collapse">
  {%- set last_year = '1999' %}
  {%- set last_month = '00' %}
  {%- set has_open_tags = false %}

  {%- for post in posts.toArray() %}
    {%- if not post.say  %}
      {%- set year = post.date.format('YYYY') %}
      {%- set month = post.date.format('MM') %}
      
      {# 年份变更时显示年份标题 #}
      {%- if last_year != year %}
        {%- if has_open_tags %}
          </div> {# 关闭上一个月的 post-list #}
          </div> {# 关闭上一个 collection-month #}
          </div> {# 关闭上一个 collection-year #}
        {%- endif %}
        <div class="collection-year {% if last_year == '1999'  %}expanded{% else %}collapsed{% endif %}">
          <h2 class="collection-header">
          <svg class="archive-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M20 6H12L10 4H4C2.9 4 2.01 4.9 2.01 6L2 18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6ZM20 18H4V8H20V18Z" fill="currentColor"/>
</svg>


            {{ year }}{{__('symbol.year')}}
            {# 计算当前年份的文章数 #}
            {%- set year_count = 0 %}
            {%- for p in posts.toArray() %}
              {%- if not p.say and p.date.format('YYYY') == year %}
                {%- set year_count = year_count + 1 %}
              {%- endif %}
            {%- endfor %}
            <span class="archive-post-counter">({{ year_count }}{{__('symbol.post')}})</span>
          </h2>
          <div class="collection-month">
            <h3 class="collection-month-header">
              <svg class="archive-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M19 3H18V1H16V3H8V1H6V3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V8H19V19ZM7 10H12V15H7V10Z" fill="currentColor"/>
</svg>
              {{ post.date.format('MM') }}{{__('symbol.month')}}
              {# 计算当前月份的文章数 #}
              {%- set month_count = 0 %}
              {%- for p in posts.toArray() %}
                {%- if not p.say and p.date.format('YYYY') == year and p.date.format('MM') == month %}
                  {%- set month_count = month_count + 1 %}
                {%- endif %}
              {%- endfor %}
              <span class="archive-post-counter">({{ month_count }}{{__('symbol.post')}})</span>
            </h3>
            <div class="art-post-list">
        {%- set last_year = year %}
        {%- set last_month = month %}
        {%- set has_open_tags = true %}
      {%- endif %}

      {# 月份变更时显示月份标题 #}
      {%- if last_month != month %}
        {%- if last_month != '00' and has_open_tags %}
          </div> {# 关闭上一个月的 post-list #}
          </div> {# 关闭上一个 collection-month #}
        {%- endif %}
        <div class="collection-month {% if loop.first and last_year == year %}expanded{% else %}collapsed{% endif %}">
          <h3 class="collection-month-header">
            <svg class="archive-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M19 3H18V1H16V3H8V1H6V3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V8H19V19ZM7 10H12V15H7V10Z" fill="currentColor"/>
</svg>
            {{ post.date.format('MM') }}{{__('symbol.month')}}
            {# 计算当前月份的文章数 #}
            {%- set month_count = 0 %}
            {%- for p in posts.toArray() %}
              {%- if not p.say and p.date.format('YYYY') == year and p.date.format('MM') == month %}
                {%- set month_count = month_count + 1 %}
              {%- endif %}
            {%- endfor %}
            <span class="archive-post-counter">({{ month_count }}{{__('symbol.post')}})</span>
          </h3>
          <div class="art-post-list">
        {%- set last_month = month %}
        {%- set has_open_tags = true %}
      {%- endif %}

      <article class="post-item">
       <div class="black"></div>
        <time class="post-time">{{ post.date.format('DD') }}</time>
        <a class="post-title-link" href="{{ url_for(post.path) }}">
          {{ post.title or __('post.untitled') }}
        </a>
      </article>
    {%- endif %}

    {# 在最后一篇文章后关闭所有开放的标签 #}
    {%- if loop.last and has_open_tags %}
      </div> {# 关闭最后一个月的 post-list #}
      </div> {# 关闭最后一个 collection-month #}
      </div> {# 关闭最后一个 collection-year #}
    {%- endif %}
  {%- endfor %}
</div>
{% endmacro %}