{% extends '_layout.njk' %}
{% import '_macro/post-collapse.njk' as post_template with context %}


{% block title %}{{ __('title.archive') }} | {{ title }}{% endblock %}



{% block class %}archives page posts-collapse{% endblock %}



{% block content %}
<div class="blank">
</div>
<div id="content" class="site-content">
  <div id="primary" class="content-area">
  <main id="main" class="site-main" role="main">
    <header class="page-header">
      <h1 class="cat-title">
      归档</h1>
      <span class="cat-des">
        <p>
        Archives</p>
      </span>
    </header>
    <div id="main-part">
      <article class="art post">
        <div class="art-main">
          <div class="art-content">
            <div id="archives">
                {{ post_template.render(page.posts) }}                
            </div>
          </div>
        </div>
      </article>
    </div>
  </main>
      {%- if page.total > 1 and page.next_link %}
    <div id="pagination"><a href="{{ url_for(page.next_link) }}" class="">Previous</a></div>
    {%- endif %}
  </div> 
</div>
{% endblock %}