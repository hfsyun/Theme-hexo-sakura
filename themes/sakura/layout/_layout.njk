<!DOCTYPE html>
<html lang="{{ config.language }}">
<head>
  {% include '_partial/head.njk' %}
  <title>{% block title %}{% endblock %}</title>
</head>

<body class="serif isWebKit">
  <div class="scrollbar" id="bar">
  </div>

  <a href="#" class="cd-top faa-float animated"></a>
   {% include '_partial/header.njk' %}
  <section id="main-container">
  {% include '_partial/headertop.njk' %}

    <div id="page" class="site wrapper {% block class %}{% endblock %}">
       {% block content %}{% endblock %}
    </div>   

    {% include '_widget/search/insight.njk' %}
    {% include '_partial/footer.njk' %}
    <div class="openNav no-select" style="height: 50px;">
      <div class="iconflat no-select" style="width: 50px; height: 50px;">
        <div class="icon"></div>
      </div>
      <div class="site-branding search-form-submit">
        <i class="iconfont js-toggle-search iconsearch icon-search"></i>
      </div>
    </div>
  </section>
  <div id="backstretch">
    <img src="" alt="" referrerPolicy="no-referrer">
  </div>
  {% include '_partial/mheader.njk' %}
   
</body>
</html>