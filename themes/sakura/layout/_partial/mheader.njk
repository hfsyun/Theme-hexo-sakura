<div id="mo-nav" class="">
  <div class="m-avatar">
    <img src="{{  theme.avatar }}">
  </div>
  <p style="text-align: center; color: #333; font-weight: 900; font-family: 'Ubuntu', sans-serif; letter-spacing: 1.5px">{{ theme.prefixName }}</p>
  <p style="text-align: center; word-spacing: 20px;">
    {% if theme.msocial %}
      {% for key, social in theme.msocial %}
        <a href="{{ social.url }}" class="fa {{ social.fa }}" target="_blank" style="color: #{{ social.color }}; margin-left:20px"></a>
      {% endfor %}
    {% endif %}
  </p>
  <ul id="menu-new-1" class="menu">
    {% for key, menu in theme.menus %}
      <li>
        <a href="{{ url_for(menu.path) }}">
          <span class="faa-parent animated-hover">
            <i class="fa {{ menu.fa }}" aria-hidden="true"></i>
            {{ key }}
          </span>
        </a>
        {% if menu.submenus %}
          <ul class="sub-menu">
            {% for subkey, submenu in menu.submenus %}
              <li>
                <a href="{{ url_for(submenu.path) }}">
                  <i class="fa {{ submenu.fa }}" aria-hidden="true"></i>
                  {{ subkey }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</div>
<button onclick="topFunction()" class="mobile-cd-top" id="moblieGoTop" title="Go to top" style="display: none;"><i class="fa fa-chevron-up" aria-hidden="true"></i></button>