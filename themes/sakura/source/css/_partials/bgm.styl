:root{
  --border-color: rgba(0, 0, 0, 0.05);
  --content-bg-color: var(--next-global-background);
  --next-text-color: var(--next-global-text-color);
  --btn-bg: var(--next-global-button-bg);
  --btn-color: var(--next-global-button-color);
  --next-theme-color: var(--next-global-theme-color);
  --next-bgm-card-bg: var(--next-global-card-bg);
  --next-global-background: var(--next-global-background);
  }



.bgm-content {
    max-width: 1300px;
    margin: 0 auto;
}

.bangumi-rank {
  margin: 20px 0;
}

.bangumi-rank-tabs {
  display: flex;
  gap: 20px;
  margin-bottom: 15px;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.bangumi-rank-tab {
  padding: 5px 10px;
  border: 1px solid var(--border-color);
  border-radius: 4px;
  background: var(--content-bg-color);
  cursor: pointer;
  color: var(--next-text-color);
  transition: all 0.3s ease;
}

.bangumi-rank-tab:hover {
  background: var(--btn-bg);
  color: var(--next-theme-color);
}

.bangumi-rank-tab.active,
.bangumi-status-tab.active {
  background: var(--btn-bg);
  color: var(--next-theme-color);
  border: var(--next-theme-color) solid 1px;
}

.bangumi-status-tabs {
  display: flex;
  gap: 5px;
  margin-bottom: 1rem;
  flex-wrap: wrap;
  color: var(--next-text-color);
  justify-content: flex-start;
}

.bangumi-status-tab {
  padding: 0.5rem 1rem;
  border: 1px solid var(--border-color);
  border-radius: 4px;
  background: var(--content-bg-color);
  cursor: pointer;
  color: var(--next-text-color);
  transition: all 0.3s ease;
}
.bangumi-rank-tabs {
    border: 2px solid var(--next-bgm-card-bg);
    border-radius: 15px;
    padding: 2rem;
    background: var(--next-global-background);
}
.bangumi-status-tabs {
    border: 2px solid var(--next-bgm-card-bg);
    border-radius: 15px;
    padding: 2rem;
    background: var(--next-global-background);
}

.bangumi-status-tab:hover {
  background: var(--btn-bg);
  color: var(--btn-color);
}

.bangumi-rank-list {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: flex-start;
}

.bangumi-rank-item {
    display: flex;
    border-radius: 8px;
    width: 48%;
    height: 20rem;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.05);
    background: var(--next-global-background);
    +mobile() {
        width: 100%;
    }
}

.bangumi-rank-item:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
}

.bangumi-rank-cover {
    position: relative;
    height: 100%;
    aspect-ratio: 75 / 106;
    overflow: hidden;
}

.bangumi-rank-cover img {
    object-fit: cover;
    position: absolute;
    height: 100%;
    width: 100%;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    color: transparent;
}

.bangumi-rank-info {
  flex: 1;
  padding: 1rem 1.2rem .5rem;
  display: flex;
  flex-direction: column;
}

.bangumi-rank-title h3 {
  margin: 0 0 0.5rem;
  line-height: 1.3;
  font-weight: bold;
  font-size: 1.8rem;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
.bangumi-rank-title div {
  font-size: 1.3rem;
  line-height: 1.3;
}
.bangumi-rank-date {
  color: var(--text-secondary-color);
  font-size: 1.4rem;
  margin-bottom: 0.5rem;
}

.bangumi-rank-meta {
  display: flex;
  justify-content: space-between;
  font-size: 1.4rem;
  color: var(--text-secondary-color);
  margin-top: 0.5rem;
}

.bangumi-rank-score-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.bangumi-rank-score {
  display: flex;
  align-items: center;
  font-size: 1.2rem;
  font-weight: bold;
  color: #ffba31;
}

.bangumi-rank-score .score-value {
  margin-right: 0.3rem;
}

.bangumi-rank-score .score-total {
  font-size: 1.4rem;
  opacity: 0.7;
}

.bangumi-rank-views {
  font-size: 1.4rem;
  svg {
    margin-right: 0.6rem;
    vertical-align: middle;
  }
}

.bangumi-rank-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin: 0.5rem 0;
  overflow: hidden;
  justify-content: flex-start;
}

.bangumi-rank-tag {
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  font-size: 1.3rem;
  background-color: rgba(255, 186, 49, 0.1);
  color: var(--next-theme-color);
}

.empty {
  grid-column: 1 / -1;
  padding: 2rem;
  text-align: center;
  color: var(--text-secondary-color);
}

.loading {
  grid-column: 1 / -1;
  padding: 2rem;
  text-align: center;
  color: var(--text-secondary-color);
}

.error {
  grid-column: 1 / -1;
  padding: 2rem;
  text-align: center;
  color: #ff6b6b;
}

.bangumi-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 7rem;
  gap: 1rem;
}

.pagination-btn {
  padding: 1rem 5rem;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--next-bgm-pagination-bg);
  cursor: pointer;
  transition: all 0.3s ease;
}

.pagination-btn:hover:not(:disabled) {
  background: var(--next-bgm-pagination-bg);
  color: var(--btn-color);
}

.pagination-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.page-info {
    padding: .5rem 5rem;
    font-size: 1.5rem;
    border-radius: 8px;
    font-weight: 600;
  background: var(--next-bgm-pagination-bg);
  color: var(--text-secondary-color);
}

@media (max-width: 767px) {
  .bangumi-rank-list {
    grid-template-columns: 1fr;
  }
}
.bangumi-progress {
  height: 6px;
  background-color: #f0f0f0;
  border-radius: 3px;
  margin: 0.5rem 0;
  position: relative;
}

.progress-bar {
  height: 100%;
  background-color: #ffba31;
  border-radius: 3px;
}

.progress-text {
  position: absolute;
  right: 0;
  top: -20px;
  font-size: 1.3rem;
  color: var(--text-secondary-color);
}
.bangumi-score-value {
    font-size: 3.6rem;
    line-height: 3.6rem;
    font-weight: bold;
    color: var(--next-theme-color);
}
