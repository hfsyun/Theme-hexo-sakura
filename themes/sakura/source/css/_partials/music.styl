/* 音乐播放器Tab样式 */
.music-tabs {
  margin-bottom: 20px;
  
  .music-nav-tabs {
    background: var(--content-bg-color);
    display: flex;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
    border-bottom: 2px solid var(--border-color);
    list-style: none;
    
    .music-tab {
      flex-grow: 1;
      text-align: center;
      border-right: 1px solid var(--border-color);
      transition: all 0.3s ease;
      
      &:last-child {
        border-right: none;
      }
      
      a {
        display: block;
        padding: 12px 16px;
        color: var(--text-color);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s ease;
        
        &:hover {
          background: var(--btn-default-hover-bg);
          color: var(--next-theme-color);
        }
      }
      
      &.active {
        background: var(--btn-default-bg);
        border-bottom: 3px solid var(--link-color);
        
        a {
          color: var(--next-theme-color);
          font-weight: 600;
        }
      }
    }
  }
  
  .music-tab-content {
    background: var(--content-bg-color);
    border: 1px solid var(--border-color);
    border-top: none;
    border-radius: 0 0 6px 6px;
    
    .music-tab-pane {
      padding: 15px;
      display: none;
      
      &.active {
        display: block;
      }
      
      /* 播放列表样式 */
      ol {
        list-style: none;
        padding: 0;
        margin: 0;
        max-height: 300px;
        overflow-y: auto;
        
        /* 自定义滚动条 */
        &::-webkit-scrollbar {
          width: 6px;
        }
        
        &::-webkit-scrollbar-track {
          background: var(--scrollbar-track-color);
          border-radius: 3px;
        }
        
        &::-webkit-scrollbar-thumb {
          background: var(--scrollbar-thumb-color);
          border-radius: 3px;
          
          &:hover {
            background: var(--scrollbar-thumb-hover-color);
          }
        }
      }
      
      li {
        padding: 8px 12px;
        border-bottom: 1px solid var(--border-color-light);
        cursor: pointer;
        transition: all 0.2s ease;
        border-radius: 4px;
        margin-bottom: 2px;
        
        &:hover {
          background: var(--btn-default-hover-bg);
        }
        
        &.active {
          background: var(--link-color-light);
          border-color: var(--link-color);
          
          .info span:first-child {
            color: var(--link-color);
            font-weight: 600;
          }
        }
        
        .info {
          display: flex;
          flex-direction: column;
          
          span:first-child {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-color);
            margin-bottom: 2px;
          }
          
          span:last-child {
            font-size: 12px;
            color: var(--text-color-light);
          }
        }
      }
    }
  }
}

/* 响应式设计 */
@media (max-width: 768px) {
  .music-tabs {
    .music-nav-tabs {
      flex-direction: column;
      
      .music-tab {
        border-right: none;
        border-bottom: 1px solid var(--border-color);
        
        &:last-child {
          border-bottom: none;
        }
      }
    }
  }
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .music-tabs {
    .music-nav-tabs {
      background: var(--content-bg-color-dark);
      border-bottom-color: var(--border-color-dark);
      
      .music-tab {
        border-right-color: var(--border-color-dark);
        
        a {
          color: var(--text-color-dark);
          
          &:hover {
            background: var(--btn-default-hover-bg-dark);
            color: var(--btn-default-hover-color-dark);
          }
        }
        
        &.active {
          background: var(--btn-default-bg-dark);
          
          a {
            color: var(--link-color-dark);
          }
        }
      }
    }
    
    .music-tab-content {
      background: var(--content-bg-color-dark);
      border-color: var(--border-color-dark);
    }
  }
}